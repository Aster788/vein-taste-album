{
  "name": "vein-taste-album",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "node scripts/generate-photo-manifest.mjs && node scripts/generate-font-subsets.mjs",
    "prebuild": "node scripts/generate-photo-manifest.mjs && node scripts/generate-font-subsets.mjs",
    "fonts:subset": "node scripts/generate-font-subsets.mjs",
    "photos:manifest": "node scripts/generate-photo-manifest.mjs",
    "photos:thumbs": "node scripts/generate-photo-thumbs.mjs",
    "photos:upload-r2": "node scripts/upload-photos-to-r2.mjs",
    "photos:upload-thumbs-r2": "node scripts/upload-photos-to-r2.mjs --thumbs-only",
    "env:pull-vercel": "vercel env pull .env.vercel --environment=preview --yes",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "data:sync": "node scripts/sync-data-from-xlsx.mjs",
    "data:export-translations": "node scripts/export-static-translations.mjs",
    "audit:photo-magic": "node scripts/scan-photo-magic.mjs",
    "photos:list-tallest": "node scripts/list-tallest-photos.mjs",
    "audit:boundary-offsets": "node scripts/audit-boundary-offsets.mjs",
    "audit:boundary-offsets:ci": "node scripts/audit-boundary-offsets.mjs --fail-on-regression --min-delta-pct=0 --max-open-rings=0 --max-invalid-lnglat=0",
    "audit:multi-branch": "node scripts/audit-multi-branch-groups.mjs",
    "audit:doc-links": "node scripts/audit-doc-links.mjs",
    "audit:filenames": "node scripts/audit-filenames.mjs",
    "assets:bookshelf-back-strip": "node scripts/generate-bookshelf-back-strip.mjs",
    "audit:map-cities": "node scripts/audit-map-cities.mjs",
    "audit:all": "npm run audit:filenames && npm run audit:photo-magic && npm run audit:doc-links",
    "hooks:install": "node scripts/install-precommit-hook.mjs"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "framer-motion": "^11.18.2",
    "gcoord": "^1.0.7",
    "heic2any": "^0.0.4",
    "mapbox-gl": "^3.22.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.49.1",
    "sharp": "^0.33.5",
    "subset-font": "^2.5.0",
    "vercel": "^54.7.1",
    "vite": "^5.4.11"
  }
}
