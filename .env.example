# Copy to .env.local and fill real values. Never commit .env.local or .env.vercel.
# Vercel CLI output goes to .env.vercel only: npm run env:pull-vercel

VITE_MAPBOX_TOKEN=your_token_here
# Public Blob root (no trailing slash), e.g. https://xxxxx.public.blob.vercel-storage.com
VITE_PHOTOS_BASE_URL=
VITE_ENABLE_MT=false
VITE_GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key
VITE_MT_CACHE_TTL_DAYS=3650

# Node / Python scripts (no VITE_ prefix)
AMAP_WEB_KEY=your_amap_web_service_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# From Vercel Storage connect (or npm run env:pull-vercel → .env.vercel)
BLOB_READ_WRITE_TOKEN=
