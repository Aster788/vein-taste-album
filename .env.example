# Copy to .env.local and fill real values. Never commit .env.local or .env.vercel.
# Optional: npm run env:pull-vercel writes .env.vercel (Vercel CLI vars only; does not overwrite .env.local).

VITE_MAPBOX_TOKEN=your_mapbox_token_here
# Photo CDN root (no trailing slash). Production example:
# https://photos.veintastealbum.com
# Dev smoke test (r2.dev, not for long-term production):
# https://pub-xxxxxxxx.r2.dev
VITE_PHOTOS_BASE_URL=
VITE_ENABLE_MT=false
VITE_GOOGLE_TRANSLATE_API_KEY=your_google_translate_api_key
VITE_MT_CACHE_TTL_DAYS=3650

# Node scripts (no VITE_ prefix)
AMAP_WEB_KEY=your_amap_web_service_key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Cloudflare R2 — photos:upload-r2 only (from R2 → Manage R2 API tokens)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=vein-taste-album-photos
